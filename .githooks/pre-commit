#!/bin/sh
# Pre-commit hook: ensure CLAUDE.md and AGENTS.md stay in sync.
# These files must be identical — one is for Claude Code, the other for
# multi-agent tooling. If you update one, copy it to the other.

if [ -f CLAUDE.md ] && [ -f AGENTS.md ]; then
    if ! diff -q CLAUDE.md AGENTS.md > /dev/null 2>&1; then
        echo ""
        echo "ERROR: CLAUDE.md and AGENTS.md have drifted out of sync."
        echo ""
        echo "These files must be identical. To fix:"
        echo "  cp CLAUDE.md AGENTS.md   # if CLAUDE.md is the source of truth"
        echo "  cp AGENTS.md CLAUDE.md   # if AGENTS.md is the source of truth"
        echo ""
        echo "Then stage the updated file and retry your commit."
        exit 1
    fi
fi
