{
  "name": "goldfish",
  "version": "6.3.3",
  "description": "Claude Code plugin — persistent developer memory with checkpoints, recall, plans, and standups",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun run src/server.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "build": "bun build src/server.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai-agent",
    "developer-tools",
    "claude-code"
  ],
  "author": "anortham",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.7.6",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "fuse.js": "^7.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
